<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_route_step"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTramoHorario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="21:19 - 21:23"
            android:textColor="#1F2937"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvTramoDistancia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="148 m, 4 min"
            android:textColor="#374151"
            android:textSize="12sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTramoTipo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:text="foot"
        android:textColor="#111827"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTramoDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Moyua"
        android:textColor="#2563EB"
        android:textSize="13sp" />

</LinearLayout>