<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootRuta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_route_card"
    android:elevation="3dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerRuta"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/tvNumeroRuta"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="1."
            android:textColor="#1F2937"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvResumenRuta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="21:19  🚶  🚇  🚶  21:31"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFlechaRuta"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="▼"
            android:textColor="#111827"
            android:textSize="18sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDetalleRuta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8F1FF"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/containerTramos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnVerRutaMapa"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#0B7A32"
            android:text="VER RUTA EN MAPA"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
